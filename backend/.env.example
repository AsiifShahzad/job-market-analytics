# JobPulse AI Backend Configuration
# Copy this file to .env and fill in your actual values

# PostgreSQL connection string (Neon)
# Format: postgresql+asyncpg://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Adzuna API credentials
# Get from https://developer.adzuna.com/
ADZUNA_APP_ID=your_app_id_here
ADZUNA_API_KEY=your_api_key_here
ADZUNA_KEYWORDS="python javascript java aws react developer"

# API Configuration
API_PORT=8000
DEBUG=false

# Database logging (set to true for SQL echo)
SQL_ECHO=false

# Environment
ENVIRONMENT=development
